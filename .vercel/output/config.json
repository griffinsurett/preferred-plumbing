{
	"version": 3,
	"routes": [
		{
			"src": "^/(.*)/$",
			"headers": {
				"Location": "/$1"
			},
			"status": 308
		},
		{
			"src": "^/about$",
			"headers": {
				"Location": "/about-us"
			},
			"status": 301
		},
		{
			"src": "^/aboutus$",
			"headers": {
				"Location": "/about-us"
			},
			"status": 301
		},
		{
			"src": "^/ecommerce-platform$",
			"headers": {
				"Location": "/projects/ecommerce-platform"
			},
			"status": 301
		},
		{
			"src": "^/legal/cookie-policy$",
			"headers": {
				"Location": "/cookie-policy"
			},
			"status": 301
		},
		{
			"src": "^/legal/privacy-policy$",
			"headers": {
				"Location": "/privacy-policy"
			},
			"status": 301
		},
		{
			"src": "^/legal/terms-of-service$",
			"headers": {
				"Location": "/terms-of-service"
			},
			"status": 301
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/.*$",
			"dest": "/404.html",
			"status": 404
		}
	]
}
---
// src/pages/index.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { siteData, ctaData } from "@/content/siteData";
import { query, sortByDate, sortByOrder } from "@/utils/query";
import FrontPageHero from "@/layouts/FrontPageHero.astro";
import HomeAboutSection from "@/components/Home/HomeAboutSection.astro";
---

<BaseLayout title="Home" description={siteData.description}>
  <main class="flex-1">
    <!-- Hero ContentRenderer with static content -->
    <FrontPageHero
      title={siteData.tagline}
      description="Professional plumbing services you can count on. From emergency repairs to new installations, we deliver quality workmanship with honest pricing."
      primaryCTA={ctaData}
    />

    <div class="bg-text">
      <HomeAboutSection />
      <ContentRenderer
        query={query("services").orderBy(sortByOrder()).limit(6)}
        variant="ServicesImageCardsVariant"
        title="Complete Plumbing Services for Repairs, Upgrades, and Protection"
        description="From emergency plumbing and leak repair to water heaters, remodel work, sump pump protection, and property plumbing support, Preferred Plumbing covers the work that keeps homes and buildings running right."
        columns={3}
      />
    </div>

    <div class="homepage-content bg-primary text-text">
      <ContentRenderer
        query={query("benefits").orderBy(sortByOrder()).limit(6)}
        variant="WhyChooseUsVariant"
        title="Why homeowners choose Preferred Plumbing."
        description="Fast response, clear communication, and workmanship that is handled carefully from the first visit through the finished result."
      />

      <!-- <ContentRenderer query={query("about-us")} variant="AccordionVariant" /> -->

      <!-- Services - auto-populates from services meta -->
      <!-- <ContentRenderer
        query={query("services").orderBy(sortByOrder())}
        variant="GridVariant"
        columns={3}
        gap="lg"
      /> -->

      <!-- Filtered query - still gets meta from authors -->
      <!-- <ContentRenderer
        query={query("authors").where(whereArrayContains("tags", "featured"))}
        variant="GridVariant"
        columns={3}
        gap="lg"
      /> -->

      <!-- Testimonials with rating filter -->
      <div class="homepage-testimonials bg-text">
        <ContentRenderer
          query={query("testimonials").where((entry) => entry.data.rating >= 4).orderBy(sortByOrder())}
          variant="GoogleReviewsCarouselVariant"
          id="testimonials"
          title="Why Customers Choose Preferred Plumbing"
          description="A quick look at the kind of service homeowners and builders keep calling out in public Google reviews."
          summaryRating={5}
          summaryCount={72}
          summaryLabel="Google Reviews"
          summaryUrl="https://reviews.birdeye.com/preferred-plumbing-of-nj-166787370757944"
        />
      </div>

      <!-- FAQ ContentRenderer -->
      <!-- <ContentRenderer
        query={query("faq").orderBy(sortByOrder())}
        variant="AccordionVariant"
        allowMultiple={false}
      /> -->

      <!-- Contact ContentRenderer -->
      <ContentRenderer
        query={query("contact-us")}
        variant="ContactVariant"
        columns={2}
      />

      <!-- Blog with limit - auto-populates from blog meta -->
      <!-- <ContentRenderer
        query={query("blog").limit(2)}
        variant="BlogVariant"
        columns={2}
      /> -->

      <!-- Multi-collection query - requires manual title/description -->
      <!-- <ContentRenderer
        query={query(["blog", "projects"]).orderBy(sortByDate()).limit(10)}
        variant="ListVariant"
        title="Recent Updates"
        description="Latest from our blog and portfolio"
      /> -->
    </div>
  </main>
</BaseLayout>

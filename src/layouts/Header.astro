---
// src/layouts/Header.astro
/**
 * Site Header with Navigation
 */
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { related } from "@/utils/query";
import { siteData } from "@/content/siteData";
---

<header class="sticky top-0 z-[40] bg-bg shadow-sm">
  <div class="">
    <div class="flex items-center justify-between h-16 w-full">
      <!-- Logo -->
      <a
        href="/"
        class="text-2xl font-bold text-heading hover:text-primary transition-colors"
      >
        {siteData.title}
      </a>

      <!-- Navigation Menu using query -->
      <ContentRenderer
        query={related("menu-items", "menu", "main-menu")}
        variant="MenuVariant"
        mode="responsive"
        className="header-navigation"
        hamburgerTransform={true}
      />
    </div>
  </div>
</header>

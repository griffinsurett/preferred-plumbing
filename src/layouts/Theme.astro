---
// src/layouts/Theme.astro
/**
 * Theme Component - Site Branding and Icons
 * 
 * Handles:
 * - Favicon configuration (multiple sizes and formats)
 * - Apple touch icons
 * - Theme color for mobile browsers
 * - PWA manifest
 */

import "../styles/global.css";
import "../integrations/scroll-animations/styles/animations.css";
import { siteData } from "@/content/siteData";
---

<!-- Favicons -->
<link rel="shortcut icon" href="/favicons/favicon.ico" sizes="any" />
<link rel="icon" type="image/x-icon" href="/favicons/favicon.ico" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicons/favicon-16x16.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32x32.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png" />
<link rel="manifest" href="/favicons/site.webmanifest" />

<!-- Mobile browser configuration -->
<meta name="mobile-web-app-capable" content="yes" />
<meta name="application-name" content={siteData.title} />
<meta name="apple-mobile-web-app-title" content={siteData.title} />
<meta name="theme-color" content="#233746" />
<meta name="msapplication-TileColor" content="#233746" />

<!-- Scroll animations (deferred to avoid blocking initial render) -->
<script>
  // Import observer directly to avoid pulling in React via index barrel exports
  import "@/integrations/scroll-animations/observer";
</script>

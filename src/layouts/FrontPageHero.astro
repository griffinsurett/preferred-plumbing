---
// src/layouts/FrontPageHero.astro
/**
 * Front Page Hero Layout
 *
 * Full-width hero section with optimized background media for homepage.
 */

import Button from "@/components/Button/Button";
import { siteData, ctaData } from "@/content/siteData";
import backgroundImage from "@/assets/background-img.jpg";
import newHeroFrame from "@/assets/new-hero-frame.png";
import plumberImage from "@/assets/plumber.webp";
import { find } from "@/utils/query";
import { formatPhoneNumber } from "@/utils/string";
import preferredWordmark from "@/assets/just-preferred/just-pref-blue-white.png";


export interface Props {
  title?: string;
  description?: string;
  image?: any;
  video?: {
    src: string;
    autoPlay?: boolean;
    muted?: boolean;
    loop?: boolean;
    playsInline?: boolean;
    controls?: boolean;
    preload?: string;
  };
  primaryCTA?: {
    text: string;
    link: string;
  };
  secondaryCTA?: {
    text: string;
    link: string;
  };
  className?: string;
  id?: string;
  minHeight?: string;
}

const {
  title = "Welcome",
  description = siteData.description,
  image,
  video,
  primaryCTA = {
    text: ctaData.text,
    link: ctaData.link,
  },
  secondaryCTA,
  className = "",
  id = "hero",
} = Astro.props;

const phoneEntry = await find("contact-us", "phone");
const phoneValue = String(phoneEntry?.data?.description ?? "").trim();
const phoneHref = phoneValue ? `${phoneEntry?.data?.linkPrefix || "tel:"}${phoneValue}` : undefined;
const resolvedSecondaryCTA =
  secondaryCTA ||
  (phoneHref
    ? {
        text: formatPhoneNumber(phoneValue),
        link: phoneHref,
      }
    : undefined);

---

<section id={id} class={`relative bg-accent ${className}`}>
  <div class="relative min-h-[160vh]">
    <div class="pointer-events-none absolute top-0 right-0 bottom-0 z-20 hidden w-[min(34vw,31rem)] translate-x-[4%] lg:block xl:w-[min(36vw,34rem)]">
      <div
        class="sticky flex h-screen items-end overflow-hidden"
        style="top: 0;"
        aria-hidden="true"
      >
        <img
          src={plumberImage.src}
          alt=""
          class="block h-auto w-full translate-y-[3.5rem]"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>

    <div class="relative h-[100vh] overflow-hidden">
      <div
        class="hero-bg absolute inset-0 bg-no-repeat"
        style={`background-image: url('${newHeroFrame.src}'), linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('${backgroundImage.src}');`}
        aria-hidden="true"
      ></div>

      <div class="relative z-10 flex h-screen w-full items-center justify-start px-8 md:px-12 lg:px-16 lg:pr-[24rem] xl:px-20 xl:pr-[32rem]">
        <div class="max-w-3xl text-left text-heading">
            <h1 class="h1">
              {title}
            </h1>

            <p class="mt-4 max-w-2xl text-sm font-black uppercase tracking-[0.16em] text-white/90 sm:text-base md:text-lg">
              {siteData.serviceAreaMessage}
            </p>

            {
              description && (
                <p class="mt-5 mb-5 max-w-2xl text-xl leading-relaxed text-text opacity-95 md:text-2xl">
                  {description}
                </p>
              )
            }

            <div class="flex flex-wrap justify-start gap-4">
              {
                primaryCTA && (
                  <Button
                    href={primaryCTA.link}
                    variant="primary"
                    size="lg"
                    className="shadow-xl hover:shadow-2xl transition-shadow"
                  >
                    {primaryCTA.text}
                  </Button>
                )
              }

              {
                resolvedSecondaryCTA && (
                  <Button href={resolvedSecondaryCTA.link} variant="secondary" size="lg">
                    {resolvedSecondaryCTA.text}
                  </Button>
                )
              }
            </div>
        </div>
      </div>
    </div>

    <div
      id="about"
      class="under-hero relative min-h-[60vh] lg:py-10 px-8 md:px-12 lg:px-16 lg:pr-[24rem] xl:px-20 xl:pr-[32rem]"
    >
      <div class="w-full text-left pt-10">
        <h2
          class="text-white font-medium"
          style="font-family: var(--font-tt-lakes);"
        >
          <span class="block text-[clamp(3rem,5vw,6rem)] leading-[0.84]">Your</span>
          <span class="mt-3">
            <img
              src={preferredWordmark.src}
              alt="Preferred"
              class="block h-14 w-auto md:h-20"
            />
          </span>
          <span class="mt-2 block text-[clamp(3rem,5vw,6rem)] leading-[0.84]">Choice</span>
          <span class="block text-[clamp(3rem,5vw,6rem)] leading-[0.84]">In Plumbing.</span>
        </h2>

        <p class="mt-8 max-w-[40rem] text-base leading-relaxed text-white/90 md:text-lg lg:text-xl">
          Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has
          been the industry's standard dummy text ever since the 1500s, when an unknown printer took
          a galley of type and scrambled it to make a type specimen book. It has survived not only
          five centuries, but also the leap into electronic typesetting, remaining essentially
          unchanged. It was popularised in the 1960s with the release of Letraset sheets containing
          Lorem Ipsum passages, and more recently with desktop publishing software like Aldus
          PageMaker including versions of Lorem Ipsum.
        </p>

        {
          primaryCTA && (
            <div class="mt-8">
              <Button
                href={primaryCTA.link}
                variant="tertiary"
                size="lg"
                className="shadow-xl hover:shadow-2xl transition-shadow"
              >
                {primaryCTA.text}
              </Button>
            </div>
          )
        }

        <div class="mt-10 flex justify-center lg:hidden" aria-hidden="true">
          <img
            src={plumberImage.src}
            alt=""
            class="block h-auto w-full max-w-[20rem]"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-bg {
    background-position: center, center, center;
    background-size: 100% 100%, cover, cover;
  }

  @media (min-width: 1024px) {
    .hero-bg {
      background-attachment: scroll, fixed, fixed;
    }
  }

  @media (max-width: 1023px) {
    .hero-bg {
      background-position: 24% 38%, 42% 38%, 42% 38%;
      background-size: auto 116%, cover, cover;
    }
  }

  h1,
  h2,
  p {
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
  }
</style>
